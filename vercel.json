{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.hcaptcha.com https://hcaptcha.com https://plausible.io https://assets.calendly.com https://*.calendly.com; frame-src 'self' https://hcaptcha.com https://*.hcaptcha.com https://drive.google.com https://www.youtube.com https://calendly.com https://*.calendly.com; style-src 'self' 'unsafe-inline' https://hcaptcha.com https://fonts.googleapis.com https://assets.calendly.com; connect-src 'self' https://hcaptcha.com https://*.hcaptcha.com https://plausible.io https://*.sanity.io https://*.apicdn.sanity.io https://calendly.com https://*.calendly.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com https://assets.calendly.com; object-src 'none'; base-uri 'self'; form-action 'self' https://formspree.io; frame-ancestors 'none'; upgrade-insecure-requests;"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
